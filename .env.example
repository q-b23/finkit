# =============================================================================
# FinKit Environment Variables
# =============================================================================
# Copy this file to .env.local (or .env.development.local) and fill in real values.
# WARNING: .env* files are gitignored — never commit real secrets or credentials.
# =============================================================================

# ---------------------------------------------------------------------------
# Base URL (used by sitemap, robots.txt, OG tags, canonical URLs, JSON-LD)
# ---------------------------------------------------------------------------
FINKIT_BASE_URL="https://getfinkit.com"

# ---------------------------------------------------------------------------
# Plausible Analytics (privacy-first, no cookies)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="getfinkit.com"

# ---------------------------------------------------------------------------
# Reddit API — Server-side only (used by api/reddit-post.js)
# ---------------------------------------------------------------------------
REDDIT_USER=""
REDDIT_PASS=""
REDDIT_CLIENT=""
REDDIT_SECRET=""

# ---------------------------------------------------------------------------
# Resend Email Delivery
# ---------------------------------------------------------------------------
RESEND_API_KEY=
